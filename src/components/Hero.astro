---
import { site } from "../data/site";
---

<section class="relative hero-gradient">
  <div class="mx-auto max-w-3xl px-6 pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="fade-in-up">
      <p
        class="inline-flex items-center gap-2 text-xs font-medium tracking-wide uppercase text-ink-500 dark:text-ink-400"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping"
          ></span>
          <span
            class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"
          ></span>
        </span>
        Based in {site.location}
      </p>

      <h1
        class="mt-6 text-4xl sm:text-6xl font-semibold tracking-tight leading-[1.05]"
      >
        Hi, I'm {site.name.split(" ")[0]}.
        <span class="block text-ink-500 dark:text-ink-400">
          {site.tagline}
        </span>
      </h1>

      <p
        class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600 dark:text-ink-300"
      >
        {site.bio}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-full bg-ink-900 dark:bg-white text-white dark:text-ink-900 px-5 py-2.5 text-sm font-medium hover:opacity-90 transition-opacity"
        >
          Get in touch
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href={site.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-ink-200 dark:border-ink-800 px-5 py-2.5 text-sm font-medium hover:bg-ink-100 dark:hover:bg-ink-800 transition-colors"
        >
          LinkedIn
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17 17 7"></path>
            <path d="M7 7h10v10"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
