---
import { engagements, conferences } from "../data/site";
---

<section
  id="speaking"
  class="scroll-mt-20 border-t border-ink-100 dark:border-ink-900"
>
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-24">
    <header class="reveal">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">
        Speaking & Mentorship
      </h2>
      <p class="mt-2 text-sm text-ink-500 dark:text-ink-400">
        Talks, panels, and mentorship across academia and industry.
      </p>
    </header>

    <div class="mt-10 grid sm:grid-cols-5 gap-10">
      <div class="sm:col-span-2">
        <h3
          class="font-mono text-xs uppercase tracking-wide text-ink-500 dark:text-ink-400"
        >
          Universities
        </h3>
      </div>
      <ul
        class="sm:col-span-3 divide-y divide-ink-100 dark:divide-ink-900 -mt-4 sm:mt-0"
      >
        {
          engagements.map((e, i) => (
            <li
              class="reveal py-4 first:pt-0 flex items-baseline justify-between gap-4"
              style={`--reveal-delay: ${i * 50}ms`}
            >
              <div>
                <p class="font-medium tracking-tight">
                  {e.role}
                  <span class="text-ink-500 dark:text-ink-400 font-normal">
                    {" "}
                    · {e.org}
                  </span>
                </p>
                {e.detail && (
                  <p class="mt-0.5 text-sm text-ink-600 dark:text-ink-400">
                    {e.detail}
                  </p>
                )}
              </div>
              <span class="shrink-0 font-mono text-xs text-ink-500 dark:text-ink-400 tabular-nums">
                {e.years}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-12 grid sm:grid-cols-5 gap-10">
      <div class="sm:col-span-2">
        <h3
          class="font-mono text-xs uppercase tracking-wide text-ink-500 dark:text-ink-400"
        >
          Conferences
        </h3>
      </div>
      <ul
        class="sm:col-span-3 divide-y divide-ink-100 dark:divide-ink-900 -mt-4 sm:mt-0"
      >
        {
          conferences.map((c, i) => (
            <li
              class="reveal py-4 first:pt-0 flex items-baseline justify-between gap-4"
              style={`--reveal-delay: ${i * 50}ms`}
            >
              <div>
                <p class="font-medium tracking-tight">{c.name}</p>
                <p class="mt-0.5 text-sm text-ink-600 dark:text-ink-400">
                  {c.detail}
                </p>
              </div>
              <span class="shrink-0 font-mono text-xs text-ink-500 dark:text-ink-400 tabular-nums">
                {c.year}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
