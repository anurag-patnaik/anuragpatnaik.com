---
import { stats } from "../data/site";
---

<section class="border-y border-ink-100 dark:border-ink-900">
  <div class="mx-auto max-w-3xl px-6 py-8">
    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-6">
      {
        stats.map((s, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 80}ms`}>
            <dt class="font-mono text-xs uppercase tracking-wide text-ink-500 dark:text-ink-400">
              {s.label}
            </dt>
            <dd class="mt-1 text-2xl sm:text-3xl font-semibold tracking-tight tabular-nums">
              {s.value}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
