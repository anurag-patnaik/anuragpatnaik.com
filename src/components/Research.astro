---
import { papers } from "../data/site";
---

<section
  id="research"
  class="scroll-mt-20 border-t border-ink-100 dark:border-ink-900"
>
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-24">
    <header class="reveal flex items-baseline justify-between">
      <div>
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">
          Research
        </h2>
        <p class="mt-2 text-sm text-ink-500 dark:text-ink-400">
          Academic and industry research published using products I've built.
        </p>
      </div>
      <span class="font-mono text-xs text-ink-500 dark:text-ink-400">
        {papers.length} papers
      </span>
    </header>

    <ul class="mt-8 space-y-4">
      {
        papers.map((p, i) => (
          <li class="reveal" style={`--reveal-delay: ${i * 70}ms`}>
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-2xl border border-ink-200/70 dark:border-ink-800 bg-white dark:bg-ink-900/60 p-6 transition-all hover:border-ink-300 dark:hover:border-ink-700 hover:shadow-sm"
            >
              <div class="flex items-baseline justify-between gap-4">
                <span class="font-mono text-xs uppercase tracking-wide text-accent">
                  {p.venue}
                </span>
                <span class="font-mono text-xs text-ink-500 dark:text-ink-400">
                  {p.product}
                </span>
              </div>
              <h3 class="mt-2 font-semibold tracking-tight leading-snug">
                {p.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-600 dark:text-ink-300">
                {p.excerpt}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-ink-500 dark:text-ink-400 group-hover:text-accent transition-colors">
                Read paper
                <svg
                  class="h-3 w-3 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M7 17 17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
