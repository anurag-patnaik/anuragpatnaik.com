---
import { education, expertise } from "../data/site";
---

<section
  id="background"
  class="scroll-mt-20 border-t border-ink-100 dark:border-ink-900"
>
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-24">
    <div class="grid sm:grid-cols-5 gap-10">
      <div class="sm:col-span-2">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">
          Background
        </h2>
        <p class="mt-3 text-sm text-ink-600 dark:text-ink-400">
          Education and areas of expertise built up across 17 years in industry
          and research.
        </p>
      </div>

      <div class="sm:col-span-3 space-y-8">
        <div>
          <h3
            class="font-mono text-xs uppercase tracking-wide text-ink-500 dark:text-ink-400"
          >
            Education
          </h3>
          <ul class="mt-3 space-y-4">
            {
              education.map((d) => (
                <li>
                  <div class="flex items-baseline justify-between gap-4">
                    <p class="font-medium tracking-tight">{d.school}</p>
                    <span class="shrink-0 font-mono text-xs text-ink-500 dark:text-ink-400 tabular-nums">
                      {d.year}
                    </span>
                  </div>
                  <p class="mt-0.5 text-sm text-ink-600 dark:text-ink-400">
                    {d.degree}
                  </p>
                  <p class="text-xs text-ink-500 dark:text-ink-500">
                    {d.location}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3
            class="font-mono text-xs uppercase tracking-wide text-ink-500 dark:text-ink-400"
          >
            Core expertise
          </h3>
          <ul class="mt-3 flex flex-wrap gap-2">
            {
              expertise.map((tag) => (
                <li class="rounded-full border border-ink-200 dark:border-ink-800 px-3 py-1 text-xs text-ink-700 dark:text-ink-300">
                  {tag}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
