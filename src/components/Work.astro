---
import { roles } from "../data/site";
import WorkCard from "./WorkCard.astro";
---

<section id="work" class="scroll-mt-20">
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-24">
    <header class="reveal flex items-baseline justify-between">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">Work</h2>
      <span class="font-mono text-xs text-ink-500 dark:text-ink-400">
        {roles.length} roles
      </span>
    </header>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        roles.map((role, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 90}ms`}>
            <WorkCard role={role} />
          </div>
        ))
      }
    </div>
  </div>
</section>
