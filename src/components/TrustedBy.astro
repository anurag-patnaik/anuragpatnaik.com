---
import { trustedBy } from "../data/site";
---

<section class="border-t border-ink-100 dark:border-ink-900">
  <div class="mx-auto max-w-3xl px-6 py-12">
    <p
      class="font-mono text-xs uppercase tracking-wide text-ink-500 dark:text-ink-400 text-center"
    >
      Products I've led are trusted by
    </p>
    <ul
      class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm text-ink-600 dark:text-ink-300"
    >
      {
        trustedBy.map((name, i) => (
          <>
            <li class="font-medium tracking-tight">{name}</li>
            {i < trustedBy.length - 1 && (
              <li
                class="hidden sm:inline-block h-1 w-1 rounded-full bg-ink-300 dark:bg-ink-700"
                aria-hidden="true"
              />
            )}
          </>
        ))
      }
    </ul>
  </div>
</section>
